# Supabase (client-side, safe to expose — RLS protects the data)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Resend (server-side only, used by /api serverless functions — never prefix with VITE_)
RESEND_API_KEY=

# Supabase service role (server-side only, used by /api serverless functions for privileged writes)
SUPABASE_SERVICE_ROLE_KEY=
